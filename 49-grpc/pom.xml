<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml - Modulo 49 gRPC
  Spring Boot 4.1.0 + Java 21.

  NOTA IMPORTANTE:
  - La libreria 'grpc-spring-boot-starter' (net.devh) NO es compatible con Spring Boot 4.1.0
    a la fecha de este modulo (autoconfig rota, dependencia transitiva de Boot 3.x).
  - Por eso este modulo usa gRPC VANILLA (io.grpc:grpc-netty-shaded + grpc-protobuf + grpc-stub)
    sin autoconfiguracion Spring Boot.
  - Ademas, en vez de generar codigo con 'protobuf-maven-plugin' (que requiere resolver
    'protoc' binario para el OS del desarrollador), este modulo demo SIMULA el servicio gRPC
    con un componente Spring puro para que el alumno vea el patron sin luchar con el codegen.
  - El .proto esperado esta documentado en README.md.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/>
    </parent>

    <groupId>com.springroadmap</groupId>
    <artifactId>grpc</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>49-grpc</name>
    <description>gRPC vanilla demo simplificado con Spring Boot 4.1.0</description>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <grpc.version>1.68.1</grpc.version>
        <protobuf.version>3.25.5</protobuf.version>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- gRPC vanilla: incluimos las 3 librerias core aunque en este demo simplificado
             solo usemos las clases publicas de io.grpc para explicar en comentarios.
             En un modulo REAL con codegen, generariamos stubs a partir de .proto. -->
        <dependency>
            <groupId>io.grpc</groupId>
            <artifactId>grpc-netty-shaded</artifactId>
            <version>${grpc.version}</version>
        </dependency>
        <dependency>
            <groupId>io.grpc</groupId>
            <artifactId>grpc-protobuf</artifactId>
            <version>${grpc.version}</version>
        </dependency>
        <dependency>
            <groupId>io.grpc</groupId>
            <artifactId>grpc-stub</artifactId>
            <version>${grpc.version}</version>
        </dependency>
        <dependency>
            <groupId>com.google.protobuf</groupId>
            <artifactId>protobuf-java</artifactId>
            <version>${protobuf.version}</version>
        </dependency>
        <!-- Necesaria para las clases generadas por protoc (@javax.annotation.Generated). -->
        <dependency>
            <groupId>javax.annotation</groupId>
            <artifactId>javax.annotation-api</artifactId>
            <version>1.3.2</version>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>grpc-1.0.0</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
