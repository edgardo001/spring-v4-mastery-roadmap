<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml - Modulo 61: RSocket con Spring Boot 4.1.0
  Coordenadas Maven consistentes con el roadmap:
    groupId    = com.springroadmap
    artifactId = rsocket
    version    = 1.0.0
    finalName  = rsocket-1.0.0 (artefacto -> target/rsocket-1.0.0.jar)
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>4.1.0</version>
        <relativePath/>
    </parent>

    <groupId>com.springroadmap</groupId>
    <artifactId>rsocket</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>61-rsocket</name>
    <description>RSocket con Spring Boot 4.1.0 (request/response, stream, fire-and-forget)</description>

    <properties>
        <java.version>21</java.version>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- Starter RSocket: aporta el servidor RSocket sobre TCP/WebSocket y el mapeo @MessageMapping. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-rsocket</artifactId>
        </dependency>

        <!-- Starter WebFlux: aporta Netty + tipos reactivos (Mono/Flux) usados en RSocket y el bridge HTTP. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-webflux</artifactId>
        </dependency>

        <!-- Test starter: JUnit 5, AssertJ, Mockito. -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Reactor Test: StepVerifier para probar streams Flux. -->
        <dependency>
            <groupId>io.projectreactor</groupId>
            <artifactId>reactor-test</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <finalName>rsocket-1.0.0</finalName>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
